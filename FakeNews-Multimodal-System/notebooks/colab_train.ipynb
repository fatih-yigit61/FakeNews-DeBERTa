   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Veri Dizinlerini Yapılandırma\n",
    "\n",
    "Drive'daki veriyi projenin `data/` dizinine sembolik link ile bağlıyoruz.  \n",
    "Bu sayede kod hiç değişmeden Drive'daki veriyi bulur."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "# ============================================================\n",
    "# BURASI SİZİN DRIVE YAPISINA GÖRE AYARLANMALI\n",
    "# Drive'da veri şu yapıda olmalı:\n",
    "#\n",
    "# fakenews_data/\n",
    "# ├── train-articles/              (SemEval makale .txt dosyaları)\n",
    "# ├── train-labels-task2-technique-classification/  (SemEval etiketler)\n",
    "# └── upfd/\n",
    "#     └── news_content.json        (UPFD, opsiyonel)\n",
    "# ============================================================\n",
    "\n",
    "DRIVE_DATA = \"/content/drive/MyDrive/fakenews_data\"  # <-- kendi yolunuzu yazın\n",
    "\n",
    "LOCAL_DATA = os.path.join(PROJECT_ROOT, \"data\")\n",
    "os.makedirs(LOCAL_DATA, exist_ok=True)\n",
    "\n",
    "# Sembolik linkler oluştur\n",
    "links = {\n",
    "    \"train-articles\": os.path.join(DRIVE_DATA, \"train-articles\"),\n",
    "    \"train-labels-task2-technique-classification\": os.path.join(DRIVE_DATA, \"train-labels-task2-technique-classification\"),\n",
    "    \"upfd\": os.path.join(DRIVE_DATA, \"upfd\"),\n",
    "}\n",
    "\n",
    "for link_name, source_path in links.items():\n",
    "    link_path = os.path.join(LOCAL_DATA, link_name)\n",
    "    if os.path.exists(source_path):\n",
    "        if not os.path.exists(link_path):\n",
    "            os.symlink(source_path, link_path)\n",
    "        print(f\"  OK  data/{link_name} → {source_path}\")\n",
    "    else:\n",
    "        print(f\"  EKSIK  {source_path} — bu klasör Drive'da bulunamadı\")\n",
    "\n",
    "# Doğrulama\n",
    "print(\"\\ndata/ içeriği:\")\n",
    "for item in os.listdir(LOCAL_DATA):\n",
    "    full = os.path.join(LOCAL_DATA, item)\n",
    "    n = len(os.listdir(full)) if os.path.isdir(full) else \"-\"\n",
    "    print(f\"  {item}/ ({n} dosya)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Outputs Dizinini Drive'a Bağlama (İsteğe Bağlı)\n",
    "\n",
    "Checkpoint ve eğitim geçmişinin Drive'a kaydedilmesi için."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DRIVE_OUTPUTS = \"/content/drive/MyDrive/fakenews_outputs\"  # <-- Drive'da çıktı klasörü\n",
    "os.makedirs(DRIVE_OUTPUTS, exist_ok=True)\n",
    "os.makedirs(os.path.join(DRIVE_OUTPUTS, \"model1\"), exist_ok=True)\n",
    "os.makedirs(os.path.join(DRIVE_OUTPUTS, \"gnn_features\"), exist_ok=True)\n",
    "\n",
    "LOCAL_OUTPUTS = os.path.join(PROJECT_ROOT, \"outputs\")\n",
    "\n",
    "if not os.path.exists(LOCAL_OUTPUTS):\n",
    "    os.symlink(DRIVE_OUTPUTS, LOCAL_OUTPUTS)\n",
    "    print(f\"outputs/ → {DRIVE_OUTPUTS} bağlandı\")\n",
    "else:\n",
    "    print(\"outputs/ zaten mevcut\")\n",
    "\n",
    "print(\"\\nOutputs dizini:\", os.listdir(LOCAL_OUTPUTS))"
   ]
  },
