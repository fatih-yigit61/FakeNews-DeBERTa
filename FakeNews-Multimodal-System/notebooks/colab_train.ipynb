  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Veri Ön İzleme (Opsiyonel)\n",
    "\n",
    "Eğitim başlamadan önce veri setinin doğru yüklenip yüklenmediğini kontrol eder."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from configs.config import TrainerConfig\n",
    "from src.preprocessing.data_loader import SemEvalParser\n",
    "\n",
    "cfg = TrainerConfig()\n",
    "\n",
    "print(\"SemEval ayrıştırılıyor...\")\n",
    "parser = SemEvalParser(cfg.articles_dir, cfg.labels_dir)\n",
    "samples = parser.parse()\n",
    "\n",
    "n_pos = sum(s.label for s in samples)\n",
    "n_neg = len(samples) - n_pos\n",
    "\n",
    "print(f\"\\nToplam örnek  : {len(samples):,}\")\n",
    "print(f\"Propagasyon   : {n_pos:,}  ({n_pos/len(samples)*100:.1f}%)\")\n",
    "print(f\"Normal        : {n_neg:,}  ({n_neg/len(samples)*100:.1f}%)\")\n",
    "print(f\"Makale sayısı : {len({s.article_id for s in samples})}\")\n",
    "print(f\"\\nÖrnek cümle   : {samples[0].text[:80]}...\")\n",
    "print(f\"Etiketi       : {'PROPAGASYON' if samples[0].label else 'normal'}\")\n",
    "\n",
    "if n_pos == 0:\n",
    "    print(\"\\n!!! UYARI: Hiç propagasyon etiketi yok! Veri yolu yanlış olabilir.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. Eğitim Konfigürasyonu"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from configs.config import TrainerConfig\n",
    "\n",
    "cfg = TrainerConfig(\n",
    "    # Veri yolları (6. hücredeki symlink ile otomatik çalışır)\n",
    "    articles_dir=\"data/train-articles\",\n",
    "    labels_dir=\"data/train-labels-task2-technique-classification\",\n",
    "    upfd_dir=\"data/upfd\",\n",
    "    output_dir=\"outputs/model1\",\n",
    "    gnn_output_dir=\"outputs/gnn_features\",\n",
    "\n",
    "    # Eğitim hyperparameter'ları\n",
    "    num_epochs=5,\n",
    "    batch_size=64,\n",
    "    learning_rate=2e-5,\n",
    "    gradient_accum=2,          # efektif batch = 128\n",
    "    fp16=True,                 # A100/T4 için mixed precision\n",
    "    early_stopping_patience=2, # 2 epoch iyileşme yoksa dur\n",
    "\n",
    "    # Kayıp ağırlıkları\n",
    "    lambda_sentiment=0.5,\n",
    "    lambda_manipulation=1.0,\n",
    "    use_focal_loss=True,\n",
    "\n",
    "    # Diğer\n",
    "    seed=42,\n",
    "    val_split=0.15,\n",
    "    normalize_style=True,\n",
    "    layer_lr_decay=0.95,\n",
    ")\n",
    "\n",
    "print(\"Konfigürasyon hazır:\")\n",
    "print(f\"  Model       : {cfg.model_name}\")\n",
    "print(f\"  Batch       : {cfg.batch_size} × {cfg.gradient_accum} = {cfg.batch_size * cfg.gradient_accum} efektif\")\n",
    "print(f\"  Epoch       : maks {cfg.num_epochs}, patience={cfg.early_stopping_patience}\")\n",
    "print(f\"  fp16        : {cfg.fp16}\")\n",
    "print(f\"  lr          : {cfg.learning_rate}  (katman çürümesi: {cfg.layer_lr_decay})\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Eğitim — Sıfırdan Başlat\n",
    "\n",
    "> **Not:** Bu hücre T4 GPU'da yaklaşık **45–90 dakika** sürer.  \n",
    "> En iyi checkpoint otomatik kaydedilir; erken durdurma aktif."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.training.text_trainer import Model1ExpertTrainer\n",
    "from src.features.gnn_exporter import GNNFeatureExporter\n",
    "import time\n",
    "\n",
    "start = time.time()\n",
    "\n",
    "trainer = Model1ExpertTrainer(cfg)\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"Adım 1/4: Veri yükleniyor...\")\n",
    "trainer.load_data()\n",
    "\n",
    "print(\"\\nAdım 2/4: Model oluşturuluyor...\")\n",
    "trainer.build_model()\n",
    "total_params = sum(p.numel() for p in trainer.model.parameters())\n",
    "print(f\"  Toplam parametre: {total_params:,} (~{total_params/1e6:.0f}M)\")\n",
    "\n",
    "print(\"\\nAdım 3/4: Eğitim başlıyor...\")\n",
    "trainer.train()\n",
    "\n",
    "elapsed = (time.time() - start) / 60\n",
    "print(f\"\\nEğitim tamamlandı. Süre: {elapsed:.1f} dk\")\n",
    "print(f\"En iyi composite skor: {trainer.best_f1:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 12. En İyi Modeli Yükle ve Doğrula"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Adım 4/4: En iyi model yükleniyor...\")\n",
    "trainer.load_best_model()\n",
    "\n",
    "# Test çıkarımı\n",
    "test_texts = [\n",
    "    \"SHOCKING: Scientists PROVE vaccines cause autism — Government hiding the truth!\",\n",
    "    \"The central bank raised interest rates by 25 basis points to curb inflation.\",\n",
    "    \"BREAKING: Secret documents reveal aliens control world governments!\",\n",
    "]\n",
    "\n",
    "print(\"\\n--- Çıkarım Testi ---\")\n",
    "for text in test_texts:\n",
    "    result = trainer.predict(text)\n",
    "    print(f\"\\nMetin    : {text[:60]}...\")\n",
    "    print(f\"Sahte    : {result['fake_class']} ({result['fake_score']:.3f})\")\n",
    "    print(f"Manipül. : {result['manipulation_score']:.3f}\")\n",
    "    print(f\"Duygu    : {result['sentiment_class']} ({result['sentiment_intensity']:.2f})\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 13. Eğitim Geçmişi Grafiği"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "history_path = \"outputs/model1/training_history.json\"\n",
    "with open(history_path) as f:\n",
    "    history = json.load(f)\n",
    "\n",
    "epochs = [h[\"epoch\"] for h in history]\n",
    "train_loss = [h[\"train_loss\"] for h in history]\n",
    "val_loss = [h[\"total_loss\"] for h in history]\n",
    "manip_f1 = [h[\"manipulation_f1\"] for h in history]\n",
    "composite = [h[\"composite_score\"] for h in history]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "axes[0].plot(epochs, train_loss, \"b-o\", label=\"Train Loss\")\n",
    "axes[0].plot(epochs, val_loss, \"r-o\", label=\"Val Loss\")\n",
    "axes[0].set_title(\"Loss Eğrisi\")\n",
    "axes[0].set_xlabel(\"Epoch\")\n",
    "axes[0].legend()\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "axes[1].plot(epochs, manip_f1, \"g-o\", label=\"Manipulation F1\")\n",
    "axes[1].plot(epochs, composite, \"purple\", linestyle=\"--\", marker=\"s\", label=\"Composite Score\")\n",
    "axes[1].set_title(\"Metrik Eğrisi\")\n",
    "axes[1].set_xlabel(\"Epoch\")\n",
    "axes[1].legend()\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "best_epoch = max(history, key=lambda h: h[\"composite_score\"])[\"epoch\"]\n",
    "for ax in axes:\n",
    "    ax.axvline(x=best_epoch, color=\"orange\", linestyle=\":\", alpha=0.7, label=f\"Best (epoch {best_epoch})\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"outputs/model1/training_curves.png\", dpi=150, bbox_inches=\"tight\")\n",
    "plt.show()\n",
    "print(f\"Grafik kaydedildi: outputs/model1/training_curves.png\")"
   ]
  },
