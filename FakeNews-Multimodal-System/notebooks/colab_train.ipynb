    "import sys\n",
    "import os\n",
    "\n",
    "# Proje kök dizinine geç\n",
    "PROJECT_ROOT = \"/content/FakeNews-Multimodal-System\"\n",
    "os.chdir(PROJECT_ROOT)\n",
    "\n",
    "# Python import path'e ekle\n",
    "if PROJECT_ROOT not in sys.path:\n",
    "    sys.path.insert(0, PROJECT_ROOT)\n",
