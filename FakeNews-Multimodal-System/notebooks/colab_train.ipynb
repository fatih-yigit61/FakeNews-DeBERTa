    "    print(f\"  ENHANCED_DIM    : {ENHANCED_DIM}   (CLS 768 + style_proj 64)\")\n",
    "    print(f\"  MANIP_EMBED_DIM : {MANIP_EMBED_DIM}   (GNN düğüm özellik boyutu)\")\n",
    "    print(f\"  STYLE_FEAT_DIM  : {STYLE_FEAT_DIM}     (ham stilometrik özellik sayısı)\")\n",
    "except ImportError as e:\n",
    "    print(f\"Import hatası: {e}\")\n",
    "    print(\"Lütfen 5. hücreyi (Python path) tekrar çalıştırın.\")"
